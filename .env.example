NODE_ENV=production
AUTH_BASE_URL_V2=http://host.docker.internal:8081/v2

# Meeting recording configuration
MAX_RECORDING_DURATION_MINUTES=180
# Silence detection timeout in minutes (how long to wait before ending due to inactivity)
MEETING_INACTIVITY_MINUTES=1
INACTIVITY_DETECTION_START_DELAY_MINUTES=1
# How long to wait at lobby before timing out (in minutes)
JOIN_WAIT_TIME_MINUTES=2
# Number of retries for transient errors (WaitingAtLobbyRetryError never retries)
# RETRY_COUNT=2 means: 1 initial attempt + 2 retries = 3 total attempts
RETRY_COUNT=2

# Optional Google Meet identity.
# Prefer a dedicated, consented Google account that is invited to meetings.
# If you use CDP, launch that Chrome with --auto-accept-this-tab-capture so
# getDisplayMedia can select the current Meet tab without manual confirmation.
# GOOGLE_CHROME_CDP_URL=http://host.docker.internal:9222
# GOOGLE_CHROME_USER_DATA_DIR=/usr/src/app/.chrome/google-meet-profile
# GOOGLE_CHROME_STORAGE_STATE_PATH=/usr/src/app/.chrome/google-meet-storage-state.json
# Re-submit anonymous guest requests if Google redirects while still waiting for host admission.
GOOGLE_ANONYMOUS_JOIN_REQUEST_ATTEMPTS=10

# GCP bucket configuration for uploading debugging screenshots
GCP_ACCESS_KEY_ID=
GCP_SECRET_ACCESS_KEY=
GCP_MISC_BUCKET=
GCP_MISC_BUCKET_FOLDER=meeting-bot
GCP_DEFAULT_REGION=

# For patching the status or logs of bots
BOT_STATUS_PATCH_ENABLED=true
SCREENAPP_BACKEND_SERVICE_API_KEY=

# SPEC-045: Microsoft Teams anonymous-join CAPTCHA (Microsoft HIP image-text challenge)
# Enabled by default. When off, the bot detects the CAPTCHA and aborts the join.
TEAMS_CAPTCHA_SOLVER_ENABLED=true
# Provider: 'openai' (delegates to the orchestrator, which owns the OpenAI key —
# default, higher accuracy) or '2captcha' (external image solving service).
TEAMS_CAPTCHA_SOLVER_PROVIDER=openai
# --- provider '2captcha' ---
# API key of a 2Captcha-compatible provider (2Captcha, CapMonster, etc.)
TEAMS_CAPTCHA_SOLVER_API_KEY=
# Override for self-hosted / compatible providers (default: https://2captcha.com)
TEAMS_CAPTCHA_SOLVER_BASE_URL=https://2captcha.com
# --- provider 'openai' ---
# Orchestrator base URL for the internal CAPTCHA endpoints. Defaults to
# NOTIFY_WEBHOOK_URL minus the /bot-callback suffix; override only if needed.
ORCHESTRATOR_INTERNAL_URL=
# Audio fallback: when the image challenge is exhausted, switch to the audio
# CAPTCHA and transcribe it (lower success rate; off by default).
TEAMS_CAPTCHA_AUDIO_FALLBACK_ENABLED=false
# Seconds of the audio challenge to capture from the PulseAudio monitor.
TEAMS_CAPTCHA_AUDIO_CAPTURE_SECONDS=8
# --- shared ---
# Solve attempts before failing (each retry refreshes the challenge)
TEAMS_CAPTCHA_MAX_RETRIES=3
# Upper bound for a single solve (submit + polling the provider), in ms
TEAMS_CAPTCHA_SOLVER_TIMEOUT_MS=120000

# Redis
REDIS_CONSUMER_ENABLED=false
REDIS_QUEUE_NAME=jobs:meetbot:list
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
# docker-compose only: host port to publish the bundled redis on (default 6379).
# Set this if another local Redis already uses 6379, e.g. REDIS_PORT_HOST=6380
# REDIS_PORT_HOST=6380

# Uploader
UPLOADER_FILE_EXTENSION=.webm
# 'screenapp' | 's3' (object storage, refined by STORAGE_PROVIDER) | 'local' (filesystem)
UPLOADER_TYPE=local

# Storage provider selection when UPLOADER_TYPE=s3: 's3' (default) or 'azure'
STORAGE_PROVIDER=s3

# S3 compatible storage for recording upload
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_USE_MINIO_COMPATIBILITY=false

# Azure Blob Storage (when STORAGE_PROVIDER=azure)
# Provide ONE of the following auth methods:
# 1. Connection string
AZURE_STORAGE_CONNECTION_STRING=
# 2. Account + Key
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_KEY=
# 3. Account + SAS Token (starts with ?sv=)
AZURE_STORAGE_SAS_TOKEN=
# 4. Managed Identity (requires AZURE_STORAGE_ACCOUNT)
AZURE_USE_MANAGED_IDENTITY=false
# Required for Azure
AZURE_STORAGE_CONTAINER=
# Optional Azure settings
AZURE_BLOB_PREFIX=
AZURE_SIGNED_URL_TTL_SECONDS=3600
AZURE_UPLOAD_CONCURRENCY=4

# Local filesystem storage (when UPLOADER_TYPE=local)
# Recordings are written to disk instead of cloud storage.
# Required directory (no default). Retention/cleanup is an external responsibility (cron/operator).
LOCAL_STORAGE_DIR=./data/recordings
# Optional: public base URL to build the notification blobUrl (e.g. nginx serving the volume).
# When absent, blobUrl is a file:// absolute path.
LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:4000/recordings

# Persistent working directory for in-progress recordings.
# Point this at a mounted volume — separate from LOCAL_STORAGE_DIR — so a container
# restart doesn't lose the recording: on startup the bot finalises and uploads any
# orphaned temp file found here. When unset, falls back to ephemeral dist/_tempvideo.
RECORDING_WORK_DIR=./data/recording-work

# Notification service (optional) - triggers after recording upload completes
# Webhook notifications
NOTIFY_WEBHOOK_ENABLED=true
NOTIFY_WEBHOOK_URL=http://host.docker.internal:4000/bot-callback
NOTIFY_WEBHOOK_SECRET=

# Redis list notifications (for async job processing)
NOTIFY_REDIS_ENABLED=false
NOTIFY_REDIS_URI=
NOTIFY_REDIS_DB=1
NOTIFY_REDIS_LIST=jobs:meetbot:recordings
